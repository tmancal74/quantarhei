{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install dev dependencies",
      "type": "shell",
      "command": "uv sync --extra dev",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run unit tests",
      "type": "shell",
      "command": "uv run pytest tests/unit -v",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run integration tests",
      "type": "shell",
      "command": "uv run behave tests/behave/features",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run all tests",
      "type": "shell",
      "command": "uv run pytest tests/unit -v && uv run behave tests/behave/features",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run linter",
      "type": "shell",
      "command": "uv run ruff check quantarhei/ --fix && uv run ruff format quantarhei/",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Clean build artifacts",
      "type": "shell",
      "command": "rm -rf dist/ *.egg-info quantarhei.egg-info htmlcov/ coverage.xml .coverage* result_images/",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
